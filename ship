#!/usr/bin/env bash
#
# ship — smart git push: stage, AI-write the commit message, commit, push.
#
set -euo pipefail

NAME="$(basename "$0")"

# Bump this on every release so installed copies can detect a newer version.
SHIP_VERSION="1.0.0"
REPO_RAW="https://raw.githubusercontent.com/yosefor/ship/main/ship"
INSTALL_CMD="curl -fsSL https://raw.githubusercontent.com/yosefor/ship/main/install.sh | bash"
SHIP_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/ship"
SHIP_CONFIG_FILE="$SHIP_CONFIG_DIR/config"

# ----- pretty output --------------------------------------------------------
bold()  { printf '\033[1m%s\033[0m\n' "$1"; }
dim()   { printf '\033[2m%s\033[0m\n' "$1"; }
err()   { printf '\033[31m%s\033[0m\n' "$1" >&2; }
green() { printf '\033[32m%s\033[0m\n' "$1"; }

print_help() {
  cat <<EOF
$NAME — smart git push: stage, AI-write the commit message, commit, push.

Usage:
  $NAME [command] [options]

Commands:
  (none)            Run the smart-push flow (default)
  push              Run the smart-push flow ("$NAME push" reads naturally)
  review            Review the changes only; never commit or push
  config            Read or write ship defaults
  help              Show this help

Options:
  -n, --dry-run     Generate + show the commit message, but don't commit/push
  -r, --review      Have 'claude -p' review the diff first; only push if it
                    passes. Otherwise print what to change and stop.
      --commit-model <claude|codex>
                    Choose the commit message generator for this run.
  -h, --help        Show this help

Config:
  $NAME config commit-model              Show the default commit generator
  $NAME config commit-model claude       Use Claude by default
  $NAME config commit-model codex        Use Codex by default

What it does:
  1. Confirms you're inside a git repo
  2. Checks for any changes (staged, unstaged, or untracked)
  3. Stages everything, asks the selected model to write a commit message
  4. (with --review) asks 'claude -p' to review the diff; stops with feedback
     if it's not ready for prod
  5. Commits, then pushes to the current branch
  6. Prints the commit message and the branch
EOF
}

normalize_commit_model() {
  case "$1" in
    claude|codex) printf '%s\n' "$1" ;;
    *)
      err "$NAME: commit model must be 'claude' or 'codex'."
      exit 2
      ;;
  esac
}

read_config_value() {
  local key="$1"
  [ -f "$SHIP_CONFIG_FILE" ] || return 0
  sed -n "s/^${key}=//p" "$SHIP_CONFIG_FILE" | tail -n1
}

write_config_value() {
  local key="$1"
  local value="$2"
  mkdir -p "$SHIP_CONFIG_DIR"
  if [ -f "$SHIP_CONFIG_FILE" ]; then
    sed "/^${key}=/d" "$SHIP_CONFIG_FILE" > "$SHIP_CONFIG_FILE.tmp"
  else
    : > "$SHIP_CONFIG_FILE.tmp"
  fi
  printf '%s=%s\n' "$key" "$value" >> "$SHIP_CONFIG_FILE.tmp"
  mv "$SHIP_CONFIG_FILE.tmp" "$SHIP_CONFIG_FILE"
}

configured_commit_model() {
  local model
  model="${SHIP_COMMIT_MODEL:-}"
  if [ -z "$model" ]; then
    model="$(read_config_value commit_model)"
  fi
  if [ -z "$model" ]; then
    model="claude"
  fi
  normalize_commit_model "$model"
}

handle_config_command() {
  case "${1:-}" in
    commit-model)
      if [ "$#" -eq 1 ]; then
        configured_commit_model
        return 0
      fi
      if [ "$#" -eq 2 ]; then
        local model
        model="$(normalize_commit_model "$2")"
        write_config_value commit_model "$model"
        bold "Default commit model set to: $model"
        dim "Saved in $SHIP_CONFIG_FILE"
        return 0
      fi
      ;;
  esac

  cat >&2 <<EOF
Usage:
  $NAME config commit-model
  $NAME config commit-model claude
  $NAME config commit-model codex
EOF
  exit 2
}

# ----- args -----------------------------------------------------------------
DRY_RUN=0
REVIEW=0
REVIEW_ONLY=0
COMMIT_MODEL_OVERRIDE=""
if [ "${1:-}" = "config" ]; then
  shift
  handle_config_command "$@"
  exit 0
fi

while [ "$#" -gt 0 ]; do
  arg="$1"
  case "$arg" in
    push)                 ;;                 # accept "$NAME push", treat as no-op flag
    review)               REVIEW=1; REVIEW_ONLY=1 ;;   # "$NAME review" — review, never push
    -n|--dry-run)         DRY_RUN=1 ;;
    -r|--review)          REVIEW=1 ;;
    --commit-model)
      [ "$#" -gt 1 ] || { err "$NAME: --commit-model requires 'claude' or 'codex'."; exit 2; }
      COMMIT_MODEL_OVERRIDE="$(normalize_commit_model "$2")"
      shift
      ;;
    --commit-model=*)
      COMMIT_MODEL_OVERRIDE="$(normalize_commit_model "${arg#*=}")"
      ;;
    help|-h|--help)       print_help; exit 0 ;;
    *)
      echo "$NAME: unknown argument '$arg' (try --help)" >&2
      exit 2 ;;
  esac
  shift
done

COMMIT_MODEL="${COMMIT_MODEL_OVERRIDE:-$(configured_commit_model)}"

generate_commit_message() {
  local prompt="$1"
  local out_file

  case "$COMMIT_MODEL" in
    claude)
      command -v claude >/dev/null 2>&1 || {
        err "Could not generate a commit message: 'claude' was not found on your PATH."
        err "Set Codex as the default with: $NAME config commit-model codex"
        exit 1
      }
      printf '%s' "$prompt" | claude -p 2>/dev/null || true
      ;;
    codex)
      command -v codex >/dev/null 2>&1 || {
        err "Could not generate a commit message: 'codex' was not found on your PATH."
        err "Set Claude as the default with: $NAME config commit-model claude"
        exit 1
      }
      out_file="$(mktemp)"
      if ! printf '%s' "$prompt" | codex exec \
        --sandbox read-only \
        -c approval_policy='"never"' \
        --ephemeral \
        --color never \
        --output-last-message "$out_file" \
        - >/dev/null 2>/dev/null; then
        rm -f "$out_file"
        true
      fi
      cat "$out_file" 2>/dev/null || true
      rm -f "$out_file"
      ;;
  esac
}

sanitize_commit_message() {
  sed -e 's/^```[a-zA-Z]*$//' -e 's/^```$//' | awk '
    function ltrim(value) {
      sub(/^[[:space:]]+/, "", value)
      return value
    }
    function is_conventional_subject(value) {
      return value ~ /^(build|chore|ci|docs|feat|fix|perf|refactor|revert|style|test)(\([^)]+\))?!?:[[:space:]]+/
    }
    {
      lines[NR] = $0
      clean = ltrim($0)
      if (!first_nonempty && clean != "") {
        first_nonempty = NR
      }
      if (!start && is_conventional_subject(clean)) {
        start = NR
      }
    }
    END {
      if (start) {
        for (i = start; i <= NR; i++) print lines[i]
      } else if (first_nonempty) {
        for (i = first_nonempty; i <= NR; i++) print lines[i]
      }
    }
  '
}

# ----- update check ---------------------------------------------------------
# Fetches the latest version at most once per day and, if a newer one exists,
# prints a red notice with the update command. Always silent on any failure so
# it can never break or slow down the main flow.
check_for_update() {
  command -v curl >/dev/null 2>&1 || return 0

  local cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/ship"
  local cache_file="$cache_dir/latest_version"
  local stamp_file="$cache_dir/last_check"
  mkdir -p "$cache_dir" 2>/dev/null || return 0

  local now last remote
  now="$(date +%s 2>/dev/null || echo 0)"
  last=0
  [ -f "$stamp_file" ] && last="$(cat "$stamp_file" 2>/dev/null || echo 0)"

  # Hit the network at most once every 24h (86400s).
  if [ ! -f "$cache_file" ] || [ "$(( now - last ))" -ge 86400 ]; then
    # '|| true' is essential: under 'set -e'/'pipefail' a failed curl (offline,
    # 404, etc.) would otherwise abort this trap and leak a non-zero exit code.
    remote="$(curl -fsSL "$REPO_RAW" 2>/dev/null | grep -m1 '^SHIP_VERSION=' | cut -d'"' -f2 || true)"
    if [ -n "$remote" ]; then
      printf '%s' "$remote" > "$cache_file" 2>/dev/null || true
      printf '%s' "$now"    > "$stamp_file" 2>/dev/null || true
    fi
  fi

  [ -f "$cache_file" ] || return 0
  remote="$(cat "$cache_file" 2>/dev/null || echo "")"
  [ -n "$remote" ] || return 0

  # Notify only if the remote version is strictly newer than ours.
  if [ "$remote" != "$SHIP_VERSION" ] && \
     [ "$(printf '%s\n%s\n' "$SHIP_VERSION" "$remote" | sort -V 2>/dev/null | tail -n1)" = "$remote" ]; then
    printf '\033[31mA new version of ship is available: %s → %s\033[0m\n' "$SHIP_VERSION" "$remote" >&2
    printf '\033[31mUpdate with:\033[0m %s\n' "$INSTALL_CMD" >&2
  fi
  # Always succeed: this runs in an EXIT trap, and a non-zero return here would
  # leak into the script's exit status (e.g. make a passing review report 1).
  return 0
}
# Run the check on every exit path (success, dry-run, clean tree, or error).
trap check_for_update EXIT

# ----- 1. must be in a git repo ---------------------------------------------
if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  err "Not a git repository (or any parent up to the mount point)."
  exit 1
fi

# ----- 2. must have changes -------------------------------------------------
if [ -z "$(git status --porcelain)" ]; then
  dim "Nothing to commit — working tree is clean."
  exit 0
fi

BRANCH="$(git branch --show-current)"
[ -z "$BRANCH" ] && BRANCH="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo HEAD)"

# ----- 3. stage everything & collect the diff -------------------------------
git add -A

# Diff of staged changes. Cap the size so we never blow past the model's input
# limits on a huge changeset; the summary stat still gives full context.
DIFF="$(git diff --cached --no-color)"
STAT="$(git diff --cached --stat --no-color)"
MAX=60000
if [ "${#DIFF}" -gt "$MAX" ]; then
  DIFF="${DIFF:0:$MAX}

[diff truncated — showing first ${MAX} characters of a larger change]"
fi

# ----- 3b. (optional) review the diff before going further ------------------
# Asks claude to act as a reviewer and decide whether the change is safe to
# ship. The first line of its answer is a machine-readable verdict; the rest is
# human-facing feedback. We only continue to commit/push on a clear pass.
if [ "$REVIEW" -eq 1 ]; then
  bold "Reviewing changes…"

  REVIEW_PROMPT='You are a senior engineer doing a pre-push code review of a staged git diff.
Decide whether this change is safe and ready to ship to production.

Look for: bugs, logic errors, security issues, leaked secrets, debugging
leftovers (stray prints/console logs/commented-out code), obviously broken or
incomplete code, and anything that would clearly break production.
Do NOT block on style nitpicks, naming preferences, or missing tests alone.

Output format (STRICT):
- The VERY FIRST line must be exactly "VERDICT: APPROVE" or "VERDICT: CHANGES".
  Use APPROVE if the change is safe to ship. Use CHANGES if it must not be
  pushed as-is.
- After that first line, write concise feedback for the developer:
  * If APPROVE, a one-line summary is enough.
  * If CHANGES, list each problem as a bullet ("- ...") with the file/area and
    what to change. Be specific and actionable.
- Do NOT use markdown code fences. Do NOT mention AI, Claude, or Anthropic.

Summary stat:
'"$STAT"'

Diff:
'"$DIFF"

  REVIEW_OUT="$(printf '%s' "$REVIEW_PROMPT" | claude -p 2>/dev/null || true)"

  if [ -z "${REVIEW_OUT//[$'\t\r\n ']/}" ]; then
    err "Could not get a review (claude returned nothing)."
    err "Your changes are staged; review/commit manually if you like."
    exit 1
  fi

  # First non-empty line carries the verdict; the rest is the feedback body.
  VERDICT="$(printf '%s\n' "$REVIEW_OUT" | sed -e '/./,$!d' | head -n1)"
  FEEDBACK="$(printf '%s\n' "$REVIEW_OUT" | sed -e '/./,$!d' | tail -n +2 | sed -e '/./,$!d')"

  echo
  if printf '%s' "$VERDICT" | grep -qi 'APPROVE'; then
    green "✓ Review passed — change looks ready to ship."
    [ -n "${FEEDBACK//[$'\t\r\n ']/}" ] && printf '%s\n' "$FEEDBACK"
    echo
    if [ "$REVIEW_ONLY" -eq 1 ]; then
      dim "Review only — nothing committed or pushed. (changes remain staged)"
      exit 0
    fi
  else
    err "✗ Review requested changes — not pushing."
    echo
    if [ -n "${FEEDBACK//[$'\t\r\n ']/}" ]; then
      printf '%s\n' "$FEEDBACK"
    else
      printf '%s\n' "$REVIEW_OUT"
    fi
    echo
    dim "Your changes are staged. Address the above, then run '$NAME' again."
    # Non-zero so scripts/CI can tell the review didn't pass.
    exit 1
  fi
fi

# If we were asked to review only, we should never reach the push flow.
if [ "$REVIEW_ONLY" -eq 1 ]; then
  exit 0
fi

# ----- 4. generate the commit message ---------------------------------------
bold "Generating commit message with ${COMMIT_MODEL}…"

PROMPT='You are writing a git commit message. Below is the staged diff (and a summary stat).

Rules:
- Output ONLY the commit message. No preamble, no explanation, no markdown code fences.
- Use the Conventional Commits style: a short imperative subject line (<=72 chars),
  then a blank line, then a brief body of bullet points if the change warrants it.
- Describe what changed and why, based solely on the diff.
- Do NOT mention AI, Claude, Anthropic, Codex, OpenAI, or that the message was generated.
- Do NOT add any author name, signature, sign-off, or "Co-Authored-By" trailer.
  You only wrote the message, not the code — do not attribute authorship to anyone.

Summary stat:
'"$STAT"'

Diff:
'"$DIFF"

MSG="$(generate_commit_message "$PROMPT" | sanitize_commit_message)"

if [ -z "${MSG//[$'\t\r\n ']/}" ]; then
  err "Could not generate a commit message ($COMMIT_MODEL returned nothing)."
  err "Your changes are staged; commit manually if you like."
  exit 1
fi

echo
bold "Commit message:"
printf '%s\n' "$MSG"
echo

if [ "$DRY_RUN" -eq 1 ]; then
  dim "Dry run — nothing committed or pushed. (changes remain staged)"
  exit 0
fi

# ----- 5. commit ------------------------------------------------------------
git commit -m "$MSG" >/dev/null

# ----- 6. push to the current branch ----------------------------------------
bold "Pushing to '$BRANCH'…"
if git rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' >/dev/null 2>&1; then
  git push
else
  # No upstream set yet — set it on first push.
  git push -u origin "$BRANCH"
fi

echo
bold "✓ Pushed to branch: $BRANCH"
