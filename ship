#!/usr/bin/env bash
#
# ship — smart git push: stage, AI-write the commit message, commit, push.
#
set -euo pipefail

NAME="$(basename "$0")"

# Bump this on every release so installed copies can detect a newer version.
SHIP_VERSION="1.1.2"
REPO_RAW="https://raw.githubusercontent.com/yosefor/ship/main/ship"
INSTALL_CMD="curl -fsSL https://raw.githubusercontent.com/yosefor/ship/main/install.sh | bash"
SHIP_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/ship"
SHIP_CONFIG_FILE="$SHIP_CONFIG_DIR/config"

# ----- pretty output --------------------------------------------------------
bold()  { printf '\033[1m%s\033[0m\n' "$1"; }
dim()   { printf '\033[2m%s\033[0m\n' "$1"; }
err()   { printf '\033[31m%s\033[0m\n' "$1" >&2; }
green() { printf '\033[32m%s\033[0m\n' "$1"; }

print_help() {
  cat <<EOF
$NAME — smart git push: stage, AI-write the commit message, commit, push.

Usage:
  $NAME [command] [options]

Commands:
  (none)            Run the smart-push flow (default)
  push              Run the smart-push flow ("$NAME push" reads naturally)
  exit              Run the smart-push flow, then close this editor window
  review            Review the changes only; never commit or push
  config            Read or write ship defaults
  help              Show this help

Options:
  -n, --dry-run     Generate + show the commit message, but don't commit/push
  -r, --review      Have Codex review the diff first. If it finds issues,
                    choose to push, fix once, or auto-fix until it passes.
      --exit-editor Close this Cursor or VS Code window after a successful push.
      --commit-model <claude|codex>
                    Choose the commit message generator for this run.
      --model <model>
                    Choose the Codex model for this run.
      --review-thinking-effort <minimal|low|medium|high|xhigh>
                    Choose Codex reasoning effort for this run's review.
  -h, --help        Show this help

Config:
  $NAME config commit-model              Show the default commit generator
  $NAME config commit-model claude       Use Claude by default
  $NAME config commit-model codex        Use Codex by default
  $NAME config model                     Show the default Codex model
  $NAME config model gpt-5.6-terra       Set the default Codex model
  $NAME config review-thinking-effort    Show the default review effort
  $NAME config review-thinking-effort high
                                        Set the default review effort

What it does:
  1. Confirms you're inside a git repo
  2. Checks for any changes (staged, unstaged, or untracked)
  3. Stages everything, asks the selected model to write a commit message
  4. (with --review) asks Codex to thoroughly review the diff at high reasoning
     effort; if it blocks the push, choose to push anyway, fix once, or have
     your default Codex/Claude model fix and re-review until it passes
  5. Commits, then pushes to the current branch
  6. Prints the commit message and the branch
  7. (with exit/--exit-editor) closes this editor window after the push succeeds
EOF
}

normalize_commit_model() {
  case "$1" in
    claude|codex) printf '%s\n' "$1" ;;
    *)
      err "$NAME: commit model must be 'claude' or 'codex'."
      exit 2
      ;;
  esac
}

normalize_reasoning_effort() {
  case "$1" in
    minimal|low|medium|high|xhigh) printf '%s\n' "$1" ;;
    *)
      err "$NAME: review thinking effort must be minimal, low, medium, high, or xhigh."
      exit 2
      ;;
  esac
}

read_config_value() {
  local key="$1"
  [ -f "$SHIP_CONFIG_FILE" ] || return 0
  sed -n "s/^${key}=//p" "$SHIP_CONFIG_FILE" | tail -n1
}

write_config_value() {
  local key="$1"
  local value="$2"
  mkdir -p "$SHIP_CONFIG_DIR"
  if [ -f "$SHIP_CONFIG_FILE" ]; then
    sed "/^${key}=/d" "$SHIP_CONFIG_FILE" > "$SHIP_CONFIG_FILE.tmp"
  else
    : > "$SHIP_CONFIG_FILE.tmp"
  fi
  printf '%s=%s\n' "$key" "$value" >> "$SHIP_CONFIG_FILE.tmp"
  mv "$SHIP_CONFIG_FILE.tmp" "$SHIP_CONFIG_FILE"
}

configured_commit_model() {
  local model
  model="${SHIP_COMMIT_MODEL:-}"
  if [ -z "$model" ]; then
    model="$(read_config_value commit_model)"
  fi
  if [ -z "$model" ]; then
    model="codex"
  fi
  normalize_commit_model "$model"
}

configured_codex_model() {
  local model
  model="${SHIP_MODEL:-}"
  if [ -z "$model" ]; then
    model="$(read_config_value model)"
  fi
  if [ -z "$model" ]; then
    model="gpt-5.6-terra"
  fi
  printf '%s\n' "$model"
}

configured_review_thinking_effort() {
  local effort
  effort="${SHIP_REVIEW_THINKING_EFFORT:-}"
  if [ -z "$effort" ]; then
    effort="$(read_config_value review_thinking_effort)"
  fi
  if [ -z "$effort" ]; then
    effort="high"
  fi
  normalize_reasoning_effort "$effort"
}

handle_config_command() {
  case "${1:-}" in
    commit-model)
      if [ "$#" -eq 1 ]; then
        configured_commit_model
        return 0
      fi
      if [ "$#" -eq 2 ]; then
        local model
        model="$(normalize_commit_model "$2")"
        write_config_value commit_model "$model"
        bold "Default commit model set to: $model"
        dim "Saved in $SHIP_CONFIG_FILE"
        return 0
      fi
      ;;
    model)
      if [ "$#" -eq 1 ]; then
        configured_codex_model
        return 0
      fi
      if [ "$#" -eq 2 ]; then
        write_config_value model "$2"
        bold "Default Codex model set to: $2"
        dim "Saved in $SHIP_CONFIG_FILE"
        return 0
      fi
      ;;
    review-thinking-effort)
      if [ "$#" -eq 1 ]; then
        configured_review_thinking_effort
        return 0
      fi
      if [ "$#" -eq 2 ]; then
        local effort
        effort="$(normalize_reasoning_effort "$2")"
        write_config_value review_thinking_effort "$effort"
        bold "Default review thinking effort set to: $effort"
        dim "Saved in $SHIP_CONFIG_FILE"
        return 0
      fi
      ;;
  esac

  cat >&2 <<EOF
Usage:
  $NAME config commit-model
  $NAME config commit-model claude
  $NAME config commit-model codex
  $NAME config model
  $NAME config model gpt-5.6-terra
  $NAME config review-thinking-effort
  $NAME config review-thinking-effort high
EOF
  exit 2
}

# ----- args -----------------------------------------------------------------
DRY_RUN=0
REVIEW=0
REVIEW_ONLY=0
EXIT_EDITOR=0
COMMIT_MODEL_OVERRIDE=""
CODEX_MODEL_OVERRIDE=""
REVIEW_THINKING_EFFORT_OVERRIDE=""
if [ "${1:-}" = "config" ]; then
  shift
  handle_config_command "$@"
  exit 0
fi

while [ "$#" -gt 0 ]; do
  arg="$1"
  case "$arg" in
    push)                 ;;                 # accept "$NAME push", treat as no-op flag
    exit|quit)            EXIT_EDITOR=1 ;;   # "$NAME exit" — push, then close this editor window
    review)               REVIEW=1; REVIEW_ONLY=1 ;;   # "$NAME review" — review, never push
    -n|--dry-run)         DRY_RUN=1 ;;
    -r|--review)          REVIEW=1 ;;
    --exit-editor)        EXIT_EDITOR=1 ;;
    --commit-model)
      [ "$#" -gt 1 ] || { err "$NAME: --commit-model requires 'claude' or 'codex'."; exit 2; }
      COMMIT_MODEL_OVERRIDE="$(normalize_commit_model "$2")"
      shift
      ;;
    --commit-model=*)
      COMMIT_MODEL_OVERRIDE="$(normalize_commit_model "${arg#*=}")"
      ;;
    --model)
      [ "$#" -gt 1 ] || { err "$NAME: --model requires a Codex model name."; exit 2; }
      CODEX_MODEL_OVERRIDE="$2"
      shift
      ;;
    --model=*)
      CODEX_MODEL_OVERRIDE="${arg#*=}"
      [ -n "$CODEX_MODEL_OVERRIDE" ] || { err "$NAME: --model requires a Codex model name."; exit 2; }
      ;;
    --review-thinking-effort)
      [ "$#" -gt 1 ] || { err "$NAME: --review-thinking-effort requires a value."; exit 2; }
      REVIEW_THINKING_EFFORT_OVERRIDE="$(normalize_reasoning_effort "$2")"
      shift
      ;;
    --review-thinking-effort=*)
      REVIEW_THINKING_EFFORT_OVERRIDE="$(normalize_reasoning_effort "${arg#*=}")"
      ;;
    help|-h|--help)       print_help; exit 0 ;;
    *)
      echo "$NAME: unknown argument '$arg' (try --help)" >&2
      exit 2 ;;
  esac
  shift
done

COMMIT_MODEL="${COMMIT_MODEL_OVERRIDE:-$(configured_commit_model)}"
CODEX_MODEL="${CODEX_MODEL_OVERRIDE:-$(configured_codex_model)}"
REVIEW_THINKING_EFFORT="${REVIEW_THINKING_EFFORT_OVERRIDE:-$(configured_review_thinking_effort)}"

generate_commit_message() {
  local prompt="$1"
  local out_file

  case "$COMMIT_MODEL" in
    claude)
      command -v claude >/dev/null 2>&1 || {
        err "Could not generate a commit message: 'claude' was not found on your PATH."
        err "Set Codex as the default with: $NAME config commit-model codex"
        exit 1
      }
      printf '%s' "$prompt" | claude -p 2>/dev/null || true
      ;;
    codex)
      command -v codex >/dev/null 2>&1 || {
        err "Could not generate a commit message: 'codex' was not found on your PATH."
        err "Set Claude as the default with: $NAME config commit-model claude"
        exit 1
      }
      out_file="$(mktemp)"
      if ! printf '%s' "$prompt" | codex exec \
        --sandbox read-only \
        -c approval_policy='"never"' \
        --model "$CODEX_MODEL" \
        --ephemeral \
        --color never \
        --output-last-message "$out_file" \
        - >/dev/null 2>/dev/null; then
        rm -f "$out_file"
        true
      fi
      cat "$out_file" 2>/dev/null || true
      rm -f "$out_file"
      ;;
  esac
}

sanitize_commit_message() {
  sed -e 's/^```[a-zA-Z]*$//' -e 's/^```$//' | awk '
    function ltrim(value) {
      sub(/^[[:space:]]+/, "", value)
      return value
    }
    function is_conventional_subject(value) {
      return value ~ /^(build|chore|ci|docs|feat|fix|perf|refactor|revert|style|test)(\([^)]+\))?!?:[[:space:]]+/
    }
    {
      lines[NR] = $0
      clean = ltrim($0)
      if (!first_nonempty && clean != "") {
        first_nonempty = NR
      }
      if (!start && is_conventional_subject(clean)) {
        start = NR
      }
    }
    END {
      if (start) {
        for (i = start; i <= NR; i++) print lines[i]
      } else if (first_nonempty) {
        for (i = first_nonempty; i <= NR; i++) print lines[i]
      }
    }
  '
}

normalize_editor_app() {
  case "$1" in
    Cursor|cursor)
      printf '%s\n' "Cursor"
      ;;
    Code|code|vscode|VSCode|"VS Code"|"vs code"|"Visual Studio Code")
      printf '%s\n' "Visual Studio Code"
      ;;
    *)
      return 1
      ;;
  esac
}

detect_editor_from_env() {
  local editor_env
  editor_env="$(env 2>/dev/null | grep -E '^((VSCODE|CURSOR)[_A-Z0-9]*|TERM_PROGRAM|TERM_PROGRAM_VERSION|__CFBundleIdentifier)=' || true)"

  case "$editor_env" in
    *"Cursor.app"*|*"/Cursor/"*)
      printf '%s\n' "Cursor"
      return 0
      ;;
    *"Visual Studio Code.app"*|*"/Visual Studio Code/"*)
      printf '%s\n' "Visual Studio Code"
      return 0
      ;;
  esac

  return 1
}

detect_editor_from_process_tree() {
  local pid args ppid
  pid="$$"

  while [ -n "$pid" ] && [ "$pid" != "0" ] && [ "$pid" != "1" ]; do
    args="$(ps -p "$pid" -o args= 2>/dev/null || true)"
    case "$args" in
      *"Cursor.app"*|*"Cursor Helper"*)
        printf '%s\n' "Cursor"
        return 0
        ;;
      *"Visual Studio Code.app"*|*"Code Helper"*)
        printf '%s\n' "Visual Studio Code"
        return 0
        ;;
    esac

    ppid="$(ps -p "$pid" -o ppid= 2>/dev/null | tr -d ' ' || true)"
    [ "$ppid" != "$pid" ] || break
    pid="$ppid"
  done

  return 1
}

detect_editor_from_frontmost_app() {
  command -v osascript >/dev/null 2>&1 || return 1

  local frontmost
  frontmost="$(osascript -e 'tell application "System Events" to get name of first application process whose frontmost is true' 2>/dev/null || true)"
  [ -n "$frontmost" ] || return 1

  normalize_editor_app "$frontmost"
}

is_editor_running() {
  command -v pgrep >/dev/null 2>&1 || return 1

  case "$1" in
    Cursor)
      pgrep -x Cursor >/dev/null 2>&1 || pgrep -f "/Cursor.app/" >/dev/null 2>&1
      ;;
    "Visual Studio Code")
      pgrep -x Code >/dev/null 2>&1 || pgrep -f "/Visual Studio Code.app/" >/dev/null 2>&1
      ;;
    *)
      return 1
      ;;
  esac
}

resolve_editor_app_to_close() {
  local configured detected cursor_running code_running

  configured="${SHIP_EXIT_EDITOR_APP:-}"
  if [ -n "$configured" ]; then
    normalize_editor_app "$configured" || return 2
    return 0
  fi

  detected="$(detect_editor_from_env || true)"
  if [ -n "$detected" ]; then
    printf '%s\n' "$detected"
    return 0
  fi

  detected="$(detect_editor_from_process_tree || true)"
  if [ -n "$detected" ]; then
    printf '%s\n' "$detected"
    return 0
  fi

  detected="$(detect_editor_from_frontmost_app || true)"
  if [ -n "$detected" ]; then
    printf '%s\n' "$detected"
    return 0
  fi

  cursor_running=0
  code_running=0
  is_editor_running "Cursor" && cursor_running=1
  is_editor_running "Visual Studio Code" && code_running=1

  if [ "$cursor_running" -eq 1 ] && [ "$code_running" -eq 0 ]; then
    printf '%s\n' "Cursor"
    return 0
  fi
  if [ "$code_running" -eq 1 ] && [ "$cursor_running" -eq 0 ]; then
    printf '%s\n' "Visual Studio Code"
    return 0
  fi

  return 1
}

close_editor_window_after_push() {
  [ "$EXIT_EDITOR" -eq 1 ] || return 0

  if ! command -v osascript >/dev/null 2>&1; then
    err "Could not close editor window: osascript was not found."
    return 0
  fi

  local app
  if ! app="$(resolve_editor_app_to_close)"; then
    err "Could not decide which editor window to close."
    err "Set SHIP_EXIT_EDITOR_APP=Cursor or SHIP_EXIT_EDITOR_APP='Visual Studio Code'."
    return 0
  fi

  dim "Closing current $app window…"
  if osascript -e "tell application \"$app\" to close front window" >/dev/null 2>&1; then
    green "✓ Closed current $app window"
  else
    err "Could not close current $app window."
  fi
}

# ----- update check ---------------------------------------------------------
# Fetches the latest version at most once per day and, if a newer one exists,
# prints a red notice with the update command. Always silent on any failure so
# it can never break or slow down the main flow.
check_for_update() {
  command -v curl >/dev/null 2>&1 || return 0

  local cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/ship"
  local cache_file="$cache_dir/latest_version"
  local stamp_file="$cache_dir/last_check"
  mkdir -p "$cache_dir" 2>/dev/null || return 0

  local now last remote
  now="$(date +%s 2>/dev/null || echo 0)"
  last=0
  [ -f "$stamp_file" ] && last="$(cat "$stamp_file" 2>/dev/null || echo 0)"

  # Hit the network at most once every 24h (86400s).
  if [ ! -f "$cache_file" ] || [ "$(( now - last ))" -ge 86400 ]; then
    # '|| true' is essential: under 'set -e'/'pipefail' a failed curl (offline,
    # 404, etc.) would otherwise abort this trap and leak a non-zero exit code.
    remote="$(curl -fsSL "$REPO_RAW" 2>/dev/null | grep -m1 '^SHIP_VERSION=' | cut -d'"' -f2 || true)"
    if [ -n "$remote" ]; then
      printf '%s' "$remote" > "$cache_file" 2>/dev/null || true
      printf '%s' "$now"    > "$stamp_file" 2>/dev/null || true
    fi
  fi

  [ -f "$cache_file" ] || return 0
  remote="$(cat "$cache_file" 2>/dev/null || echo "")"
  [ -n "$remote" ] || return 0

  # Notify only if the remote version is strictly newer than ours.
  if [ "$remote" != "$SHIP_VERSION" ] && \
     [ "$(printf '%s\n%s\n' "$SHIP_VERSION" "$remote" | sort -V 2>/dev/null | tail -n1)" = "$remote" ]; then
    printf '\033[31mA new version of ship is available: %s → %s\033[0m\n' "$SHIP_VERSION" "$remote" >&2
    printf '\033[31mUpdate with:\033[0m %s\n' "$INSTALL_CMD" >&2
  fi
  # Always succeed: this runs in an EXIT trap, and a non-zero return here would
  # leak into the script's exit status (e.g. make a passing review report 1).
  return 0
}
# Run the check on every exit path (success, dry-run, clean tree, or error).
trap check_for_update EXIT

# ----- 1. must be in a git repo ---------------------------------------------
if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  err "Not a git repository (or any parent up to the mount point)."
  exit 1
fi

# ----- 2. must have changes -------------------------------------------------
if [ -z "$(git status --porcelain)" ]; then
  dim "Nothing to commit — working tree is clean."
  exit 0
fi

BRANCH="$(git branch --show-current)"
[ -z "$BRANCH" ] && BRANCH="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo HEAD)"

# ----- 3. stage everything & collect the diff -------------------------------
collect_staged_diff() {
  # Cap the diff so we never blow past the model's input limits on a huge
  # changeset; the summary stat still gives full context.
  DIFF="$(git diff --cached --no-color)"
  STAT="$(git diff --cached --stat --no-color)"
  local max=60000
  if [ "${#DIFF}" -gt "$max" ]; then
    DIFF="${DIFF:0:$max}

[diff truncated — showing first ${max} characters of a larger change]"
  fi
}

run_review() {
  local review_out_file

  REVIEW_PROMPT='You are a senior engineer doing a thorough pre-push code review of a staged git diff.
Decide whether this change is safe and ready to ship to production.

Inspect the whole diff and its likely interactions carefully. Find every real
production-affecting issue you can identify; do not stop after finding the
first issue or provide only representative examples.
Look for: bugs, logic errors, security issues, leaked secrets, debugging
leftovers (stray prints/console logs/commented-out code), obviously broken or
incomplete code, and anything that would clearly break production.
Do NOT block on style nitpicks, naming preferences, or missing tests alone.

Output format (STRICT):
- The VERY FIRST line must be exactly "VERDICT: APPROVE" or "VERDICT: CHANGES".
  Use APPROVE if the change is safe to ship. Use CHANGES if it must not be
  pushed as-is.
- After that first line, write concise feedback for the developer:
  * If APPROVE, a one-line summary is enough.
  * If CHANGES, list every problem as a bullet ("- ...") with the file/area and
    what to change. Be specific and actionable.
- Do NOT use markdown code fences. Do NOT mention AI, Claude, or Anthropic.

Summary stat:
'"$STAT"'

Diff:
'"$DIFF"

  command -v codex >/dev/null 2>&1 || {
    err "Could not get a review: 'codex' was not found on your PATH."
    err "Install Codex CLI, or review/commit manually."
    return 1
  }

  review_out_file="$(mktemp)"
  if ! printf '%s' "$REVIEW_PROMPT" | codex exec \
    --sandbox read-only \
    -c approval_policy='"never"' \
    -c "model_reasoning_effort=\"$REVIEW_THINKING_EFFORT\"" \
    --model "$CODEX_MODEL" \
    --ephemeral \
    --color never \
    --output-last-message "$review_out_file" \
    - >/dev/null 2>/dev/null; then
    rm -f "$review_out_file"
    REVIEW_OUT=""
    return 1
  fi
  REVIEW_OUT="$(cat "$review_out_file" 2>/dev/null || true)"
  rm -f "$review_out_file"

  [ -n "${REVIEW_OUT//[$'\t\r\n ']/}" ]
}

choose_review_resolution() {
  REVIEW_ACTION="abort"

  if [ ! -t 0 ] && [ ! -t 1 ]; then
    dim "Non-interactive session — leaving the reviewed changes staged."
    return 0
  fi

  local -a options=(
    "Push anyway"
    "Fix once with ${COMMIT_MODEL}, then review again"
    "Fix and review until approved with ${COMMIT_MODEL}"
  )
  local selected=0 menu_row=0 mouse_enabled=0 key next mouse_payload button row

  render_review_options() {
    local index
    for index in "${!options[@]}"; do
      printf '\r\033[2K'
      if [ "$index" -eq "$selected" ]; then
        printf '\033[7m› %s\033[0m\n' "${options[$index]}"
      else
        printf '  %s\n' "${options[$index]}"
      fi
    done
  }

  finish_review_menu() {
    [ "$mouse_enabled" -eq 1 ] && printf '\033[?1000l\033[?1006l'
    printf '\033[?25h'
  }

  echo "Choose how to continue (↑/↓ + Enter, or click in a compatible terminal):"
  # Xterm-compatible terminals report the cursor position and mouse clicks.
  # Arrow-key selection remains available when either capability is absent.
  printf '\033[6n'
  if IFS= read -rsd R -t 1 next </dev/tty && [[ "$next" =~ ^$'\033'\[([0-9]+)\;[0-9]+$ ]]; then
    menu_row="${BASH_REMATCH[1]}"
    printf '\033[?1000h\033[?1006h'
    mouse_enabled=1
  fi
  render_review_options

  while :; do
    if ! IFS= read -rsn1 key </dev/tty; then
      finish_review_menu
      dim "Could not read a selection — leaving the reviewed changes staged."
      return 0
    fi

    case "$key" in
      '')
        case "$selected" in
          0) REVIEW_ACTION="push_anyway" ;;
          1) REVIEW_ACTION="fix_once" ;;
          2) REVIEW_ACTION="fix_until_approved" ;;
        esac
        finish_review_menu
        return 0
        ;;
      $'\033')
        IFS= read -rsn1 -t 1 next </dev/tty || continue
        [ "$next" = "[" ] || continue
        IFS= read -rsn1 -t 1 next </dev/tty || continue
        case "$next" in
          A)
            selected=$(( (selected + ${#options[@]} - 1) % ${#options[@]} ))
            printf '\033[3A'
            render_review_options
            ;;
          B)
            selected=$(( (selected + 1) % ${#options[@]} ))
            printf '\033[3A'
            render_review_options
            ;;
          '<')
            mouse_payload=""
            while IFS= read -rsn1 -t 1 next </dev/tty; do
              [ "$next" = "M" ] || [ "$next" = "m" ] && break
              mouse_payload+="$next"
            done
            IFS=';' read -r button _ row <<< "$mouse_payload"
            if [ "$button" = "0" ] && [ "$row" -ge "$menu_row" ] && [ "$row" -lt $((menu_row + ${#options[@]})) ]; then
              selected=$((row - menu_row))
              printf '\033[3A'
              render_review_options
              case "$selected" in
                0) REVIEW_ACTION="push_anyway" ;;
                1) REVIEW_ACTION="fix_once" ;;
                2) REVIEW_ACTION="fix_until_approved" ;;
              esac
              finish_review_menu
              return 0
            fi
            ;;
        esac
        ;;
    esac
  done
}

fix_review_issues() {
  local fix_prompt
  fix_prompt='You are fixing a failed pre-push code review in the current repository.
Work directly in the working tree. Inspect the reported issues and the affected
code, then implement every necessary fix. Keep the change focused; do not
change unrelated code. Run relevant validation when practical.

Do not create a commit, do not push, and do not merely describe a solution:
make the edits in the working tree.

Review feedback:
'"$FEEDBACK"'

Reviewed diff summary:
'"$STAT"'

Reviewed diff:
'"$DIFF"

  bold "Fixing review issues with ${COMMIT_MODEL}…"
  case "$COMMIT_MODEL" in
    codex)
      command -v codex >/dev/null 2>&1 || {
        err "Could not fix review issues: 'codex' was not found on your PATH."
        return 1
      }
      printf '%s' "$fix_prompt" | codex exec \
        --sandbox workspace-write \
        -c approval_policy='"never"' \
        --model "$CODEX_MODEL" \
        --ephemeral \
        --color never \
        -
      ;;
    claude)
      command -v claude >/dev/null 2>&1 || {
        err "Could not fix review issues: 'claude' was not found on your PATH."
        return 1
      }
      claude -p --permission-mode acceptEdits "$fix_prompt"
      ;;
  esac
}

git add -A
collect_staged_diff

# ----- 3b. (optional) review the diff before going further ------------------
# A failed review can either be deliberately overridden or fixed by the user's
# configured default commit model. Fixes are staged and reviewed again before a
# push is allowed.
if [ "$REVIEW" -eq 1 ]; then
  AUTO_FIX_UNTIL_APPROVED=0
  while :; do
    bold "Reviewing changes…"
    if ! run_review; then
      err "Could not get a review (Codex returned nothing)."
      err "Your changes are staged; review/commit manually if you like."
      exit 1
    fi

    # First non-empty line carries the verdict; the rest is the feedback body.
    VERDICT="$(printf '%s\n' "$REVIEW_OUT" | sed -e '/./,$!d' | head -n1)"
    FEEDBACK="$(printf '%s\n' "$REVIEW_OUT" | sed -e '/./,$!d' | tail -n +2 | sed -e '/./,$!d')"

    echo
    if [ "$VERDICT" = "VERDICT: APPROVE" ]; then
      green "✓ Review passed — change looks ready to ship."
      [ -n "${FEEDBACK//[$'\t\r\n ']/}" ] && printf '%s\n' "$FEEDBACK"
      echo
      if [ "$REVIEW_ONLY" -eq 1 ]; then
        dim "Review only — nothing committed or pushed. (changes remain staged)"
        exit 0
      fi
      break
    fi

    # Keep the exact verdict contract safe: only an explicit CHANGES verdict
    # gets the interactive override/fix choices.
    if [ "$VERDICT" != "VERDICT: CHANGES" ]; then
      err "Review returned an invalid verdict — not pushing."
      printf '%s\n' "$REVIEW_OUT"
      dim "Your changes are staged; run '$NAME -r' again or review manually."
      exit 1
    fi

    err "✗ Review requested changes — not pushing yet."
    echo
    if [ -n "${FEEDBACK//[$'\t\r\n ']/}" ]; then
      printf '%s\n' "$FEEDBACK"
    else
      printf '%s\n' "$REVIEW_OUT"
    fi
    echo

    if [ "$REVIEW_ONLY" -eq 1 ]; then
      dim "Review only — nothing committed or pushed. (changes remain staged)"
      exit 1
    fi

    if [ "$AUTO_FIX_UNTIL_APPROVED" -eq 1 ]; then
      bold "Review still requested changes — fixing and reviewing again…"
      REVIEW_ACTION="fix_once"
    else
      choose_review_resolution
    fi
    case "$REVIEW_ACTION" in
      push_anyway)
        bold "Continuing without resolving the review findings…"
        echo
        break
        ;;
      fix_once|fix_until_approved)
        if [ "$REVIEW_ACTION" = "fix_until_approved" ]; then
          AUTO_FIX_UNTIL_APPROVED=1
        fi
        BEFORE_FIX_FINGERPRINT="$(git diff --cached --no-color | cksum)"
        if ! fix_review_issues; then
          err "The fixer could not complete. Your changes are staged."
          exit 1
        fi
        git add -A
        if git diff --cached --quiet; then
          dim "The fixer left no changes to commit or push."
          exit 0
        fi
        AFTER_FIX_FINGERPRINT="$(git diff --cached --no-color | cksum)"
        if [ "$AUTO_FIX_UNTIL_APPROVED" -eq 1 ] && [ "$BEFORE_FIX_FINGERPRINT" = "$AFTER_FIX_FINGERPRINT" ]; then
          err "The auto-fixer made no staged changes; returning to the choices."
          AUTO_FIX_UNTIL_APPROVED=0
        fi
        collect_staged_diff
        echo
        ;;
      *)
        dim "Your changes are staged. Address the above, then run '$NAME' again."
        # Non-zero so scripts/CI can tell the review didn't pass.
        exit 1
        ;;
    esac
  done
fi

# If we were asked to review only, we should never reach the push flow.
if [ "$REVIEW_ONLY" -eq 1 ]; then
  exit 0
fi

# ----- 4. generate the commit message ---------------------------------------
bold "Generating commit message with ${COMMIT_MODEL}…"

PROMPT='You are writing a git commit message. Below is the staged diff (and a summary stat).

Rules:
- Output ONLY the commit message. No preamble, no explanation, no markdown code fences.
- Use the Conventional Commits style: a short imperative subject line (<=72 chars),
  then a blank line, then a brief body of bullet points if the change warrants it.
- Describe what changed and why, based solely on the diff.
- Do NOT mention AI, Claude, Anthropic, Codex, OpenAI, or that the message was generated.
- Do NOT add any author name, signature, sign-off, or "Co-Authored-By" trailer.
  You only wrote the message, not the code — do not attribute authorship to anyone.

Summary stat:
'"$STAT"'

Diff:
'"$DIFF"

MSG="$(generate_commit_message "$PROMPT" | sanitize_commit_message)"

if [ -z "${MSG//[$'\t\r\n ']/}" ]; then
  err "Could not generate a commit message ($COMMIT_MODEL returned nothing)."
  err "Your changes are staged; commit manually if you like."
  exit 1
fi

echo
bold "Commit message:"
printf '%s\n' "$MSG"
echo

if [ "$DRY_RUN" -eq 1 ]; then
  dim "Dry run — nothing committed or pushed. (changes remain staged)"
  exit 0
fi

# ----- 5. commit ------------------------------------------------------------
git commit -m "$MSG" >/dev/null

# ----- 6. push to the current branch ----------------------------------------
bold "Pushing to '$BRANCH'…"
if git rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' >/dev/null 2>&1; then
  git push
else
  # No upstream set yet — set it on first push.
  git push -u origin "$BRANCH"
fi

echo
bold "✓ Pushed to branch: $BRANCH"
close_editor_window_after_push
